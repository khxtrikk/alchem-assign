# Example Environment Variables
# Copy this file to .env and fill in the values

# The URL of the API Gateway (VM 1). Workers will connect here.
III_URL=ws://VM_1_IP:80/ws

# Optional: The unique device ID for the Engine (from project.ini)
III_HOST_USER_ID=ffab62d4698500e0da6f46324bfc4ca58f57f31fe044c2432bf36995b802418c

# Generated by iii engine
RABBITMQ_USER=iii
RABBITMQ_PASS=your_rabbitmq_password
